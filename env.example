# LM Studio — points to the local OpenAI-compatible endpoint
LM_STUDIO_BASE_URL="http://localhost:1234/v1"
LM_STUDIO_MODEL="qwen3.5-35b-a3b"

# Jina AI — free tier works, grab key at https://jina.ai
JINA_API_KEY="your_jina_api_key_here"
JINA_TARGET_URL="https://youtube.trends24.in/"

# Wan2GP — set to the absolute path of your Wan2GP installation
WAN2GP_DIR="/home/your-username/AI/Wan2GP"
WAN2GP_MODEL="--t2v-14B"
WAN2GP_PROFILE="4"

# Generation mode: "wan2gp" (local GPU) or "colab" (manual free cloud)
GENERATION_MODE="wan2gp"

# Product to inject in Phase 3 (Sales Agent)
TARGET_PRODUCT="Your product name here"
